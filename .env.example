# Copie este arquivo para .env (dev) ou .env.local (overrides locais).
# Todas as vars VITE_* sao validadas em src/config/env.ts - se faltar, app falha ao iniciar.

# URLs do backend (aupus-nexon-api em dev local roda em 3001)
VITE_API_URL=http://localhost:3001/api/v1
VITE_WEBSOCKET_URL=http://localhost:3001

# Metadados do app
VITE_APP_NAME=AupusNexOn
VITE_DEFAULT_DOMAIN=http://localhost:5173
VITE_S3_URL=https://aupusdev.s3.amazonaws.com

# Monitoramento
VITE_SENTRY_DSN=
VITE_WEB_VITALS=false
VITE_STANDALONE=false

# Pusher (notificacoes)
VITE_PUSHER_APP_ID=1687561
VITE_PUSHER_APP_KEY=96911d5008cfeabb4016
VITE_PUSHER_APP_SECRET=be5cb67410530e8b5ca3
VITE_PUSHER_HOST=be5cb67410530e8b5ca3
VITE_PUSHER_PORT=be5cb67410530e8b5ca3
VITE_PUSHER_SCHEME=be5cb67410530e8b5ca3
VITE_PUSHER_APP_CLUSTER=us2
